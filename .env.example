# App General Settings
APP_NAME=personal-knowledge-base-os
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database Connection Details
# The service runs fully offline if no database is reachable (in-memory fallback).
# Use host.docker.internal when connecting from containers, or localhost from host.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
REDIS_URL=redis://localhost:6379/0

# Knowledge base settings
DEFAULT_VAULT_PATH=demo_vault
EMBEDDINGS_OFFLINE=true
CHAT_MODEL=gpt-4o-mini
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# External APIs (optional — leave unset to run fully offline)
# Setting OPENAI_API_KEY switches embeddings + chat to the real OpenAI provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
